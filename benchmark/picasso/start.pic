using "builtin/syncio";
using "builtin/array";
using "builtin/sync";

class RowWorker {
    say N: int;
    say out: [][]uint8;
    say startRow: int;
    say endRow: int;
    say wg: waitgroup;

    fn RowWorker(N: int, out: [][]uint8, startRow: int, endRow: int, wg: waitgroup) {
        this.N = N;
        this.out = out;
        this.startRow = startRow;
        this.endRow = endRow;
        this.wg = wg;
    }

    fn run() {
        say bytesPerRow: int = (this.N + int(7)) / int(8);
        say invN: double = 2.0 / double(this.N);
        say y: int = this.startRow;

        while (y < this.endRow) {
            say Ci: double = (double(y) * invN) - 1.0;
            say xByte: int = 0;

            while (xByte < bytesPerRow) {
                say res: int = 0;
                say i: int = 0;

                while (i < int(8)) {
                    say x0: int = xByte * int(8) + i;
                    say x1: int = x0 + int(1);
                    
                    say Crb0: double = (double(x0) * invN) - 1.5;
                    say Crb1: double = (double(x1) * invN) - 1.5;

                    say Zr1: double = Crb0;
                    say Zi1: double = Ci;
                    say Zr2: double = Crb1;
                    say Zi2: double = Ci;

                    say b: int = 0;
                    say j: int = 49;

                    while (j > 0) {
                        say Zr1_2: double = Zr1 * Zr1;
                        say Zi1_2: double = Zi1 * Zi1;
                        say Zr2_2: double = Zr2 * Zr2;
                        say Zi2_2: double = Zi2 * Zi2;

                        // Use addition for 2.0*Zr*Zi to match Java's internal precision
                        Zi1 = (Zr1 + Zr1) * Zi1 + Ci;
                        Zr1 = Zr1_2 - Zi1_2 + Crb0;

                        Zi2 = (Zr2 + Zr2) * Zi2 + Ci;
                        Zr2 = Zr2_2 - Zi2_2 + Crb1;

                        if ((Zr1 * Zr1 + Zi1 * Zi1) > 4.0) { 
                            b = b | int(2); 
                        }
                        if ((Zr2 * Zr2 + Zi2 * Zi2) > 4.0) { 
                            b = b | int(1); 
                        }
                        
                        if (b == int(3)) { 
                            j = 0; 
                        } else { 
                            j = j - 1; 
                        }
                    }
                    // Shift and pack
                    res = (res << int(2)) | b;
                    i = i + int(2);
                }

                this.out[y][xByte] = uint8(res ^ int(255));
                xByte = xByte + 1;
            }
            y = y + 1;
        }
        sync.waitgroup_done(this.wg);
    }
}

fn start(args: []string) {
    say N: int = 1000;
    say bytesPerRow: int = (N + int(7)) / int(8);
    say out: [][]uint8 = array.create(uint8, N, bytesPerRow);
    say wg: waitgroup = sync.waitgroup_create();

    say numThreads: int = 1; 
    say rowsPerThread: int = N / numThreads;
    
    say workers: []start.RowWorker = array.create(start.RowWorker, numThreads);

    say t: int = 0;
    while (t < numThreads) {
        say sRow: int = t * rowsPerThread;
        say eRow: int = sRow + rowsPerThread;
        if (t == (numThreads - int(1))) { eRow = N; }

        // Store the worker in the array to keep it alive
        workers[t] = new start.RowWorker(N, out, sRow, eRow, wg);
        
        sync.waitgroup_add(wg, 1);
        
        // Pass the instance method from the array-stored object
        thread(workers[t].run);
        
        t = t + 1;
    }

    // Wait for all threads to finish
    sync.waitgroup_wait(wg);
    syncio.printf("P4\n%d %d\n", N, N);
    say stdout_handle: string = syncio.get_stdout();

    say r: int = 0;
    while (r < N) {
        syncio.fwrite(stdout_handle, out[r], bytesPerRow, 0);
        r = r + 1;
    }
    syncio.fflush(stdout_handle);
}