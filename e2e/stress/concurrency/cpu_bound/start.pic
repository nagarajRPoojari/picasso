using "builtin/syncio";
using "builtin/array";
using "builtin/atomics";
class ConcurrencyStress {
    say internal TASK_COUNT: int = 100;
    say task_count: atomic int64;
    fn ConcurrencyStress() {
        atomics.store_int64(this.task_count, 0);
    }
    
    fn worker(count: int) {
        say c: int = 0;
        foreach i in 0..count {
            c = c * 100 + c - 100;
            if( c > 10 ){
                c -= 29;    
            }else {
                c += 90;
            }
        }    
        atomics.add_int64(this.task_count, 1);
        syncio.printf("TASK DONE\n");
    }

    fn testManyCPUBoundTasks() {
        foreach i in 0..this.TASK_COUNT {
            thread(this.worker, i * 100);    
        }
    }
}

fn start(args: []string) {
    say stress: start.ConcurrencyStress = new start.ConcurrencyStress();
    stress.testManyCPUBoundTasks();
}