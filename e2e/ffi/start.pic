using "c/ffi/coo";

fn start(args: []string) {
    // Test 1: Original pointer-based API (existing test)
    say xy: struct.Coordinate = coo.create(10, 200);
    coo.dump(xy);
    
    // Test 2: Bare struct return with unwrapping (multiple return values)
    say x: int, y: int = coo.create_value(1920, 1080);
    syncio.printf("%d\n", x);
    syncio.printf("%d\n", y);
    
    // Test 3: Wrapper for pointer-based API with unwrapping
    say width: int, height: int = coo.get_dimensions_wrapper();
    syncio.printf("%d\n", width);
    syncio.printf("%d\n", height);
}