using "builtin/syncio";
using "builtin/array";
using "builtin/atomics";
using "builtin/sync";
using "builtin/rterr";
using "types" as tt;

using "picasso/ex";

class Test {

    say TASK_COUNT: int = 3;

    fn Test() {
        
    }

    fn worker(count: int, wg: waitgroup) {
        say i: int = 0;
        while(i < 2) {
            syncio.printf(""); 
            i+=1;
        }   
        sync.waitgroup_done(wg);
    }

    fn tester() {
        say wg: waitgroup = sync.waitgroup_create();
        foreach i in 0..this.TASK_COUNT {
            sync.waitgroup_add(wg, 1);
            thread(this.worker, i * 100, wg);
        }
        sync.waitgroup_wait(wg);
        syncio.printf("all tasks done\n");
    }

    fn daemon(c: int) {
        say i: int = 0;
        syncio.printf("Starting loop\n");
        while(i < 100) {
            syncio.printf("i = ");
            syncio.printf("%d", i);
            syncio.printf("\n");
            i = i + 1;
        }
        syncio.printf("Loop done\n");
    }
}   

fn start() {
    say t: start.Test = new start.Test();
    thread(t.daemon, 90);
}