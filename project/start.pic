using "builtin/syncio";
using "builtin/os";
using "builtin/array";
using "builtin/strings";

fn start(args: []string) {
    if(strings.compare(args[1], "init") == 0) {
        syncio.printf("running init program\n");
        os.exit(0);
    }

    say pid: int = os.fork();
    if(pid == 0) {
            
    }

}