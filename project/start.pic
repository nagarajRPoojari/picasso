using "builtin/syncio";
using "builtin/array";
using "builtin/atomics";
using "builtin/sync";

class ConcurrencyStress {
    say internal TASK_COUNT: int = 10;

    say wg: waitgroup;

    fn ConcurrencyStress() {
        this.wg = sync.waitgroup_create();
    }
    
    fn worker(wg: waitgroup, count: int) {
        say c: int = 0;
        foreach i in 0..count {
            c = c * 100 + c - 100;
            if( c > 10 ){
                c -= 29;    
            }else {
                c += 90;
            }
        }    
        sync.waitgroup_done(wg);
    }

    fn testManyCPUBoundTasks() {
        foreach i in 0..this.TASK_COUNT {
            sync.waitgroup_add(this.wg, 1);
            thread(this.worker, this.wg, i * 100);    
        }

        sync.waitgroup_wait(this.wg);
        syncio.printf("all tasks done\n");
    }
}

fn start() {
    say stress: start.ConcurrencyStress = new start.ConcurrencyStress();
    stress.TASK_COUNT = 21;

    // syncio.printf("> %d \n", stress.TASK_COUNT);
    // stress.testManyCPUBoundTasks();

    say arr: []int = array.create(int, 100);
}