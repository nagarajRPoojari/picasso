using "builtin/syncio";
using "builtin/array";
using "builtin/atomics";
using "builtin/sync";
using "builtin/rterr";
using "types" as tt;

using "picasso/ex";

class Test {

    say x: int, y: int;

    fn Test() {
        
    }

    fn divide(a: int, b: int): (double,  ex.Error) {
        if(b==0) {
            return 0.0, new ex.RuntimeError("denominator is zero");
        }
        return a / b,  null;
    }
}

fn start() {
    say t: start.Test = new start.Test();
    say a: double, err: ex.Error = t.divide(10, 0);
    if( err != null ){
        rterr.die(err.toString());
    }
}