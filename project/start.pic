class DenominatorErr: ex.Error {
    say internal msg: string;
    fn DenominatorErr(msg: string) {
        this.msg = msg;
    }
    fn toString(): string {
        return this.msg;    
    }
}

class Test {
    fn !Test() {
        
    }
    fn !divide(a: int, b: int): double {
        if(b==0) {
            raise(new start.DenominatorErr("this is an error") ,  -1);
        }    
        return a / b;
    }
}

fn start() {
    say t: start.Test = new start.Test(): err ?  {
        
    };
    say x: ex.ErrorCatcher = new ex.ErrorCatcher();
    say a: int = 10; //
    say b: int = 0; // simulating user inputs for simplicity

    say ans:double = t.divide(a, b): err ? {
        if(err ? ex.DenominatorErr) {
            rterr.error_v2("dead");
        }else {
            return -1000;
        }
    };

    syncio.printf("ans : %f \n", ans);
}