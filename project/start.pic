using "builtin/syncio";
using "builtin/array";
using "builtin/atomics";
using "builtin/sync";
using "builtin/rterr";
using "types" as tt;

using "picasso/ex";

class Test {

    say TASK_COUNT: int = 30000;

    fn Test() {
        
    }

    fn worker(count: int, wg: waitgroup) {
        say c: int = 0;
        foreach i in 0..count {    
            c = c * 100 + c - 100;
            if (c > 10) {
                c -= 29;
            } else {
                c += 90;
            }
        }
        sync.waitgroup_done(wg);
    }

    fn tester() {
        say wg: waitgroup = sync.waitgroup_create();
        foreach i in 0..this.TASK_COUNT {
            sync.waitgroup_add(wg, 1);
            thread(this.worker, i * 100, wg);
        }
        sync.waitgroup_wait(wg);
        syncio.printf("all tasks done\n");
    }
}

fn start() {
    say t: start.Test = new start.Test();
    t.tester();
}