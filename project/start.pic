using "builtin/syncio";
using "builtin/os";
using "builtin/array";
using "builtin/strings";

fn start(args: []string) {
    if(array.len(args) > 1) {
        if(strings.compare(args[1], "init") == 0) {
            syncio.printf("running init program: PID: %d \n",os.getpid());
            os.exit(0);
        }   
    }

    syncio.printf("running parent program: PID: %d \n",os.getpid());
    say pid: int = os.fork();
    say _args: []string = array.create(string, 2);

    _args[0] = args[0];
    _args[1] = "init";


    (*
        if(pid == 0) {
            os.execvp(args[0], _args);
            os.exit(0);    
        }
    *)
}

